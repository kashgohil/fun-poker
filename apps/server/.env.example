# Copy to .env for local development.

# Postgres (matches packages/db/docker-compose.yml).
DATABASE_URL=postgres://poker:poker@localhost:5432/poker

# Better Auth. Generate a strong secret for production.
BETTER_AUTH_URL=http://localhost:8080
BETTER_AUTH_SECRET=dev-secret-change-me

# OAuth credentials. Leave blank to disable a provider (email/password still
# works). Create these in the Google Cloud Console and Apple Developer portal.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
